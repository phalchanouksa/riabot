# --- Database ---
DB_NAME=riabot-chatbot-app
DB_USER=postgres
DB_PASSWORD=your_db_password
# DB_HOST is usually just localhost for local development
DB_HOST=localhost
DB_PORT=5432

# --- Django ---
# Generate using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_django_secret_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# --- Rasa ---
RASA_URL=http://localhost:5005
# Generate using: python -c "import secrets; print(secrets.token_hex(32))"
RASA_TOKEN_SECRET=your_rasa_secret_key

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# --- Security (set all True for production with HTTPS) ---
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False
JWT_AUTH_COOKIE_SECURE=False

# Celery Task Queue
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
