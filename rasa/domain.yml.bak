# ============================================
# RiaBot Domain - University Major Counselor Chatbot
# ============================================
# Rasa acts as the dialogue controller
# TabNet ML model handles major predictions
# ============================================

version: "3.1"

intents:
  - greet
  - goodbye
  - affirm
  - deny
  - start_survey
  - answer_question
  - ask_explain
  - ask_about_major
  - ask_help
  - mood_great
  - mood_unhappy
  - out_of_scope
  - stop_survey
  - show_results
  - nlu_fallback
  - faq
  - chitchat

entities:
  - answer_value
  - major_name

slots:
  survey_active:
    type: bool
    initial_value: false
    influence_conversation: true
    mappings:
      - type: custom

  current_question_idx:
    type: float
    initial_value: -1
    influence_conversation: false
    mappings:
      - type: custom

  questions_queue:
    type: any
    initial_value: []
    influence_conversation: false
    mappings:
      - type: custom

  answers_collected:
    type: any
    initial_value: {}
    influence_conversation: false
    mappings:
      - type: custom

  questions_asked_count:
    type: float
    initial_value: 0
    influence_conversation: true
    mappings:
      - type: custom

  prediction_confidence:
    type: float
    initial_value: 0.0
    influence_conversation: true
    mappings:
      - type: custom

  predicted_major:
    type: text
    initial_value: null
    influence_conversation: false
    mappings:
      - type: custom

  survey_stage:
    type: categorical
    values:
      - profiling
      - narrowing
      - refining
      - complete
    influence_conversation: true
    mappings:
      - type: custom

  should_continue:
    type: bool
    initial_value: true
    influence_conversation: true
    mappings:
      - type: custom

  answer_value:
    type: float
    influence_conversation: false
    mappings:
      - type: from_entity
        entity: answer_value

responses:
  utter_greet:
    - text: "бһҹбһҪбһҹбҹ’бһҸбһё! рҹҳҠ бһҒбҹ’бһүбһ»бҹҶбһҲбҹ’бһҳбҹ„бҹҮ RiaBot бһҮбһ¶бһҮбҹҶбһ“бһҪбһҷбһҖбһ¶бһҡбһҺбҹӮбһ“бһ¶бҹҶбһҖбһ¶бһҡбһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһҮбҹҶбһ“бһ¶бһүбһҹбһ·бһҖбҹ’бһҹбһ¶бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҹбһ·бһҹбҹ’бһҹбһ‘бһҫбһ”бһ”бһүбҹ’бһ…бһ”бҹӢбһҗбҹ’бһ“бһ¶бһҖбҹӢбһ‘бһёбҹЎбҹў (Grade 12)бҹ”\n\nрҹ”№ **бһҹбһҪбһҡбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһ–бһёбһҹбһ¶бһӣбһ¶** (бһ§бһ‘бһ¶бһ бһҡбһҺбҹҚбҹ– бһ‘бһ¶бһҖбҹӢбһ‘бһ„бһҸбһ¶бһҳбһҺбһ¶? бһҳбһ¶бһ“бһўбһ¶бһ бһ¶бһҡбһјбһ”бһҖбһҡбһҺбҹҚбһ‘бҹҒ?)\nрҹ”№ бһ¬бһңбһ¶бһҷбһ–бһ¶бһҖбҹ’бһҷ **'start'** бһ¬ **'бһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳ'** бһҠбһҫбһҳбҹ’бһ”бһёбһ’бҹ’бһңбһҫбһҸбҹҒбһҹбҹ’бһҸбһҡбһҫбһҹбһҮбҹҶбһ“бһ¶бһүбһҗбҹ’бһ“бһ¶бһҖбҹӢбһҳбһ бһ¶бһңбһ·бһ‘бҹ’бһҷбһ¶бһӣбҹҗбһҷ!"

  utter_goodbye:
    - text: "бһўбһҡбһӮбһ»бһҺ! бһҹбһјбһҳбһҮбһҪбһ”бһӮбҹ’бһ“бһ¶бһҳбҹ’бһҸбһ„бһ‘бҹҖбһҸ рҹҳҠ бһҹбһјбһҳбһҮбһјбһ“бһ–бһҡбһІбҹ’бһҷбһўбҹ’бһ“бһҖбһ‘бһ‘бһҪбһӣбһ”бһ¶бһ“бһҮбҹ„бһӮбһҮбҹҗбһҷ! рҹҢҹ"

  utter_help:
    - text: "бһҹбһҪбһҹбҹ’бһҸбһё! бһҒбҹ’бһүбһ»бҹҶбһҮбһ¶бһҡбҹүбһјбһ”бһјбһҸ (RiaBot) бһҠбҹӮбһӣбһ”бҹҶбһ–бһ¶бһҖбҹӢбһҠбҹ„бһҷбһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһ”бһүбҹ’бһүбһ¶бһҹбһ·бһ”бҹ’бһ”бһ“бһ·бһҳбҹ’бһҳбһ·бһҸ (AI/Machine Learning)бҹ” бһ“бҹҒбҹҮбһӮбһәбһҮбһ¶бһўбҹ’бһңбһёбһҠбҹӮбһӣбһҒбҹ’бһүбһ»бҹҶбһўбһ¶бһ…бһҮбһҪбһҷбһўбҹ’бһ“бһҖбһ”бһ¶бһ“бһҷбҹүбһ¶бһ„бһӣбһҳбҹ’бһўбһ·бһҸ:\n\n**бҹЎ. бһ’бҹ’бһңбһҫбһҸбҹҒбһҹбҹ’бһҸбһҹбҹ’бһңбҹӮбһ„бһҡбһҖбһҳбһ»бһҒбһҮбҹҶбһ“бһ¶бһү (Adaptive ML Test) рҹҺҜ**\nбһҮбҹҶбһ“бһҪбһҹбһІбҹ’бһҷбһҖбһ¶бһҡбһҹбһҪбһҡбһҮбһ·бһҸбҹЈбҹ бҹ бһҹбҹҶбһҺбһҪбһҡ бһҒбҹ’бһүбһ»бҹҶбһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢбһҖбҹ’бһ”бһҪбһ“бһҡбҹүбһ¶бһҢбһёбһҹбһ¶бһҹбҹ’бһҸбҹ’бһҡ (Algorithms) бһҠбһҫбһҳбҹ’бһ”бһёбһңбһ¶бһҷбһҸбһҳбҹ’бһӣбҹғбһ‘бһ¶бҹҶбһ„ 'бһ…бҹҶбһҺбһ„бҹӢбһ…бҹҶбһҺбһјбһӣбһ…бһ·бһҸбҹ’бһҸ' бһ“бһ·бһ„ 'бһҮбҹҶбһ“бһ¶бһү' бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбҹ” бһҒбҹ’бһүбһ»бҹҶбһ“бһ№бһ„бһҹбһҪбһҡбһҹбҹҶбһҺбһҪбһҡбһ‘бҹ…бһҸбһ¶бһҳбһ…бһҳбҹ’бһӣбһҫбһҷбһҳбһ»бһ“бҹ—бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ (Adaptive) бһ бһҫбһҷбһ‘бһҹбҹ’бһҹбһ“бҹҚбһ‘бһ¶бһҷбһҳбһ»бһҒбһҮбҹҶбһ“бһ¶бһүбһҠбҹӮбһӣбһҹбҹҗбһҖбҹ’бһҸбһ·бһҹбһҳбһ”бҹҶбһ•бһ»бһҸбһ‘бһ¶бҹҶбһ„бҹЎбҹҰ бһІбҹ’бһҷбһўбҹ’бһ“бһҖбҹ” бһӣбҹ„бһҖбһўбҹ’бһ“бһҖбһӮбҹ’бһҡбһ¶бһ“бҹӢбһҸбҹӮбһ…бһ»бһ…бһӣбҹҒбһҒ бҹЎ бһҠбһӣбҹӢ бҹӨ бһ”бҹүбһ»бһҺбҹ’бһҺбҹ„бҹҮбҹ”\nрҹ‘ү _бһңбһ¶бһҷбһ–бһ¶бһҖбҹ’бһҷ **'start'** бһ¬ **'бһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳ'** бһҠбһҫбһҳбҹ’бһ”бһёбһҸбҹҒбһҹбҹ’бһҸ_\n\n**бҹў. бһҖбһ¶бһҡбһ–бһ“бҹ’бһҷбһӣбҹӢбһ–бһёбһӣбһ‘бҹ’бһ’бһ•бһӣ (Explainability) рҹ’Ў**\nбһҖбҹ’бһҡбҹ„бһҷбһҸбҹҒбһҹбҹ’бһҸбһ…бһ”бҹӢ бһҒбҹ’бһүбһ»бҹҶбһҳбһ·бһ“бһҸбҹ’бһҡбһ№бһҳбһҸбҹӮбһ”бҹ’бһҡбһ¶бһ”бҹӢбһҗбһ¶бһҡбҹҖбһ“бһўбҹ’бһңбһёбһ‘бҹҒ бһҸбҹӮбһҒбҹ’бһүбһ»бҹҶбһўбһ¶бһ…бһ”бһҖбһҹбҹ’бһҡбһ¶бһҷбһ”бҹ’бһҡбһ¶бһ”бҹӢбһ бҹҒбһҸбһ»бһ•бһӣбһҸбһ¶бһҳбһҡбһҷбҹҲбһӮбһҺбһ·бһҸбһңбһ·бһ‘бҹ’бһҷбһ¶ (Confidence & Probability) бһҗбһ¶бһ бҹҒбһҸбһ»бһўбҹ’бһңбһёбһ”бһ¶бһ“бһҮбһ¶бһўбҹ’бһ“бһҖбһҹбһҳбһ“бһ№бһ„бһҮбҹҶбһ“бһ¶бһүбһ“бҹ„бҹҮ бһ“бһ·бһ„бһҮбҹҶбһ“бһ¶бһүбһ”бһ“бҹ’бһ‘бһ¶бһ”бҹӢбһ”бһ“бҹ’бһҹбҹҶбһ•бҹ’бһҹбҹҒбһ„бһ‘бҹҖбһҸбҹ”\nрҹ‘ү _бһңбһ¶бһҷбһ–бһ¶бһҖбҹ’бһҷ **'explain'** бһ¬ **'бһ–бһ“бҹ’бһҷбһӣбҹӢ'**_\n\n**бҹЈ. бһҶбҹ’бһӣбһҫбһҷбһҹбҹҶбһҺбһҪбһҡбһўбҹҶбһ–бһёбһҹбһ¶бһҖбһӣбһңбһ·бһ‘бҹ’бһҷбһ¶бһӣбҹҗбһҷбһўбһ„бҹ’бһӮбһҡ (Angkor University FAQs) рҹҸ«**\nбһўбҹ’бһ“бһҖбһўбһ¶бһ…бһҹбһҪбһҡбһҒбҹ’бһүбһ»бҹҶбһ”бһ¶бһ“бһҠбҹ„бһҷбһҹбҹҒбһҡбһёбһўбҹҶбһ–бһёбҹ–\n- бһўбһ¶бһ бһ¶бһҡбһјбһ”бһҖбһҡбһҺбҹҚ (Scholarships)\n- бһҳбһ бһ¶бһңбһ·бһ‘бҹ’бһҷбһ¶бһӣбҹҗбһҷбһ‘бһ¶бҹҶбһ„бҹ§ бһ“бһ·бһ„бһҳбһ»бһҒбһҮбҹҶбһ“бһ¶бһү\n- бһ‘бһёбһҸбһ¶бҹҶбһ„ бһ“бһ·бһ„бһӣбҹҒбһҒбһ‘бҹҶбһ“бһ¶бһҖбҹӢбһ‘бҹҶбһ“бһ„\n- бһўбһ“бҹ’бһҸбҹҒбһңбһ¶бһҹбһ·бһҖбһҠбҹ’бһӢбһ¶бһ“ (бһҖбһ“бҹ’бһӣбҹӮбһ„бһҹбҹ’бһ“бһ¶бһҖбҹӢбһ“бҹ…) бһ“бһ·бһ„бһҖбҹ’бһӣбһ№бһ”бһ“бһ·бһҹбҹ’бһҹбһ·бһҸ\nрҹ‘ү _бһ§бһ‘бһ¶бһ бһҡбһҺбҹҚ: **'бһҸбһҫбһҳбһ¶бһ“бһўбһ¶бһ бһ¶бһҡбһјбһ”бһҖбһҡбһҺбҹҚбһ‘бҹҒ?'**_\n\n**бҹӨ. бһҖбһ¶бһҡбһ•бҹ’бһҸбһӣбҹӢбһҷбҹ„бһ”бһӣбҹӢ бһ“бһ·бһ„ бһҖбһ·бһ…бҹ’бһ…бһҹбһ“бҹ’бһ‘бһ“бһ¶бһ‘бһјбһ‘бҹ… (Chit-Chat) рҹ’¬**\nбһ‘бҹ„бҹҮбһңбһ„бҹ’бһңбҹҒбһ„ бһ¬бһҹбҹ’бһҸбҹ’бһҡбҹҒбһҹбһҡбһҝбһ„бһҡбһҫбһҹбһҮбҹҶбһ“бһ¶бһү бһҖбҹҸбһўбһ¶бһ…бһ“бһ·бһҷбһ¶бһҷбһӣбҹҒбһ„бһҮбһ¶бһҳбһҪбһҷбһҒбҹ’бһүбһ»бҹҶбһ”бһ¶бһ“бһҠбҹӮбһҡ!\n\n**бҹҘ. бһҖбһ¶бһҡбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҖбһ¶бһҡбһ’бҹ’бһңбһҫбһҸбҹҒбһҹбҹ’бһҸ вҡҷпёҸ**\n- бһңбһ¶бһҷбһ–бһ¶бһҖбҹ’бһҷ **'stop'** бһҠбһҫбһҳбҹ’бһ”бһёбһ•бҹ’бһўбһ¶бһҖбһўбһёбһЎбһјбһңбһ“бҹҒбҹҮ\n- бһңбһ¶бһҷбһ–бһ¶бһҖбҹ’бһҷ **'results'** бһҠбһҫбһҳбҹ’бһ”бһёбһҳбһҫбһӣбһӣбһ‘бҹ’бһ’бһ•бһӣбһ”бһҺбҹ’бһҸбҹ„бҹҮбһўбһ¶бһҹбһ“бҹ’бһ“"

  utter_faq/general:
    - text: "рҹҸ« **бһҹбһ¶бһҖбһӣбһңбһ·бһ‘бҹ’бһҷбһ¶бһӣбҹҗбһҷбһўбһ„бҹ’бһӮбһҡ (Angkor University - A.U.)** бһӮбһәбһҮбһ¶бһӮбҹ’бһҡбһ№бҹҮбһҹбҹ’бһҗбһ¶бһ“бһ§бһҸбҹ’бһҸбһҳбһҹбһ·бһҖбҹ’бһҹбһ¶бһҜбһҖбһҮбһ“бһҳбһҪбһҷбһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“бһ”бһ„бҹ’бһҖбһҫбһҸбһЎбһҫбһ„бһҸбһ¶бҹҶбһ„бһ–бһёбһҶбҹ’бһ“бһ¶бҹҶ бҹўбҹ бҹ бҹӨ бһҠбҹ„бһҷбһҜбһҖбһ§бһҸбҹ’бһҸбһҳ бһўбҹ’бһ“бһҖбһ§бһҖбһүбҹүбһ¶ бһ”бһҺбҹ’бһҢбһ·бһҸ бһҹбҹҖбһ„ бһҺбһ¶бҹҶбҹ” бһҹбһ¶бһӣбһ¶бһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“бһ‘бһ‘бһҪбһӣбһҹбҹ’бһӮбһ¶бһӣбҹӢбһҠбҹ„бһҷбһҖбҹ’бһҡбһҹбһҪбһ„бһўбһ”бҹӢбһҡбҹҶ бһҷбһ»бһңбһҮбһ“ бһ“бһ·бһ„бһҖбһёбһЎбһ¶ бһ“бһ·бһ„бһҖбҹ’бһҡбһҹбһҪбһ„бһҹбһ»бһҒбһ¶бһ—бһ·бһ”бһ¶бһӣбҹ”"
    
  utter_faq/faculties:
    - text: "бһҹбһ¶бһҖбһӣбһңбһ·бһ‘бҹ’бһҷбһ¶бһӣбҹҗбһҷбһўбһ„бҹ’бһӮбһҡбһҳбһ¶бһ“бһҳбһ бһ¶бһңбһ·бһ‘бҹ’бһҷбһ¶бһӣбҹҗбһҷбһ…бҹҶбһ“бһҪбһ“ бҹ§ бһӮбһәбҹ–\n1пёҸвғЈ бһҹбһ»бһҒбһ—бһ¶бһ–бһҹбһ¶бһ’бһ¶бһҡбһҺбҹҲ\n2пёҸвғЈ бһңбһ·бһ‘бҹ’бһҷбһ¶бһҹбһ¶бһҹбҹ’бһҸбҹ’бһҡ бһ“бһ·бһ„бһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶\n3пёҸвғЈ бһңбһ·бһҹбҹ’бһңбһҖбһҳбҹ’бһҳ бһ“бһ·бһ„бһҹбҹ’бһҗбһ¶бһ”бһҸбҹ’бһҷбһҖбһҳбҹ’бһҳ\n4пёҸвғЈ бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһ–бһ¶бһҺбһ·бһҮбҹ’бһҮбһҖбһҳбҹ’бһҳ бһ“бһ·бһ„бһ‘бҹҒбһҹбһ…бһҡбһҺбҹҚ\n5пёҸвғЈ бһҹбһ„бҹ’бһӮбһҳбһңбһ·бһ‘бҹ’бһҷбһ¶ бһ“бһ·бһ„бһ…бҹ’бһ”бһ¶бһ”бҹӢ\n6пёҸвғЈ бһҳбһ“бһ»бһҹбҹ’бһҹбһҹбһ¶бһҹбҹ’бһҸбҹ’бһҡ бһ“бһ·бһ„бһ—бһ¶бһҹбһ¶бһ”бһҡбһ‘бҹҒбһҹ\n7пёҸвғЈ бһҖбһҹбһ·бһҖбһҳбҹ’бһҳ"

  utter_faq/scholarships:
    - text: "рҹҺ“ бһҹбһ¶бһҖбһӣбһңбһ·бһ‘бҹ’бһҷбһ¶бһӣбҹҗбһҷбһўбһ„бҹ’бһӮбһҡбһҳбһ¶бһ“бһ•бҹ’бһҸбһӣбҹӢбһўбһ¶бһ бһ¶бһҡбһјбһ”бһҖбһҡбһҺбҹҚбһ–бһ·бһҹбҹҒбһҹбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһ“бһ·бһҹбҹ’бһҹбһ·бһҸбһҠбҹӮбһӣбһ‘бһҫбһ”бһ”бһүбҹ’бһ…бһ”бҹӢбһҳбһ’бҹ’бһҷбһҳбһҹбһ·бһҖбҹ’бһҹбһ¶бһ‘бһ»бһҸбһ·бһҷбһ—бһјбһҳбһ· (бһ”бһ¶бһҖбҹӢбһҢбһ»бһ”)! бһҖбһ¶бһҡбһ•бҹ’бһҸбһӣбҹӢбһ“бҹҒбҹҮбһӮбһәбһҠбһҫбһҳбҹ’бһ”бһёбһҮбһҪбһҷбһӮбһ¶бҹҶбһ‘бҹ’бһҡбһ•бҹ’бһ“бҹӮбһҖбһ бһ·бһҡбһүбҹ’бһүбһңбһҸбҹ’бһҗбһ»бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҹбһ·бһҹбҹ’бһҹбһҒбҹ’бһңбҹҮбһҒбһ¶бһҸ бһ“бһ·бһ„бһўбҹ’бһ“бһҖбһҠбҹӮбһӣбһҡбҹҖбһ“бһ–бһјбһҖбҹӮбҹ”"

  utter_faq/clubs:
    - text: "бһҖбҹҶбһЎбһ»бһ„бһ–бҹҒбһӣбһҹбһ·бһҖбҹ’бһҹбһ¶ бһ“бһ·бһҹбҹ’бһҹбһ·бһҸбһўбһ¶бһ…бһ…бһјбһӣбһҡбһҪбһҳбһҖбҹ’бһӣбһ№бһ”бһ“бһ·бһ„бһҹбһҖбһҳбҹ’бһҳбһ—бһ¶бһ–бһҮбһ¶бһ…бҹ’бһҡбһҫбһ“бһҠбһјбһ…бһҮбһ¶бҹ–\n- бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһ…бһ»бҹҮбһҖбһҳбҹ’бһҳбһҹбһ·бһҖбҹ’бһҹбһ¶бһҖбҹ’бһ“бһ»бһ„бһ“бһ·бһ„бһҖбҹ’бһҡбҹ…бһҹбҹ’бһҡбһ»бһҖ\n- бһҹбһ бһ—бһ¶бһ–бһҹбһ бһ–бҹҗбһ“бҹ’бһ’бһҷбһ»бһңбһҮбһ“бһҖбһҳбҹ’бһ–бһ»бһҮбһ¶ (UYFC)\n- бһҖбҹ’бһӣбһ№бһ”бһҖбһёбһЎбһ¶ (Sport Club)\n- бһҖбҹ’бһӣбһ№бһ”бһўбҹ’бһ“бһҖбһўбһ¶бһ“бһ“бһ·бһ„бһҹбһҡбһҹбҹҒбһҡ (Reading & Academic Authoring)\n- бһ“бһ·бһ„бһҖбҹ’бһӣбһ№бһ”бһўбҹ’бһ“бһҖбһҹбҹ’бһҳбҹҗбһӮбҹ’бһҡбһ…бһ·бһҸбҹ’бһҸбһ•бҹ’бһҹбҹҒбһ„бҹ—бһ‘бҹҖбһҸ!"

  utter_faq/contact:
    - text: "рҹ“Қ **бһ‘бһёбһҸбһ¶бҹҶбһ„:** бһ”бһ»бһҡбһёбһҹбҹҖбһ„бһҺбһ¶бҹҶ бһ—бһјбһҳбһ·бһҒбҹ’бһ“бһ¶бһҡ бһҹбһ„бҹ’бһҖбһ¶бһҸбҹӢбһҮбҹ’бһҡбһ¶бһң бһҖбҹ’бһҡбһ»бһ„бһҹбҹҖбһҳбһҡбһ¶бһ” бһҒбҹҒбһҸбҹ’бһҸбһҹбҹҖбһҳбһҡбһ¶бһ”\nрҹ“һ **бһ‘бһјбһҡбһҹбҹҗбһ–бҹ’бһ‘:** 017 671 825 / 070 853 537\nвңүпёҸ **бһўбҹҠбһёбһҳбҹӮбһӣ:** info@angkor.edu.kh"

  utter_faq/history:
    - text: "рҹҸ« бһҹбһ¶бһҖбһӣбһңбһ·бһ‘бҹ’бһҷбһ¶бһӣбҹҗбһҷбһўбһ„бҹ’бһӮбһҡ (Angkor University) бһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“бһ”бһ„бҹ’бһҖбһҫбһҸбһЎбһҫбһ„бһ“бҹ…бһҶбҹ’бһ“бһ¶бҹҶбҹўбҹ бҹ бҹӨ бһҠбҹ„бһҷбһҜбһҖбһ§бһҸбҹ’бһҸбһҳ бһўбҹ’бһ“бһҖбһ§бһҖбһүбҹүбһ¶ бһ”бһҺбҹ’бһҢбһ·бһҸ бһҹбҹҖбһ„ бһҺбһ¶бҹҶ бһҳбһ¶бһ“бһ‘бһёбһҸбһ¶бҹҶбһ„бһ“бҹ…бһҖбҹ’бһ“бһ»бһ„бһҒбҹҒбһҸбҹ’бһҸбһҹбҹҖбһҳбһҡбһ¶бһ”бҹ” бһҮбһ¶бһҹбһ¶бһҖбһӣбһңбһ·бһ‘бҹ’бһҷбһ¶бһӣбҹҗбһҷбһҠбҹӮбһӣбһ‘бһ‘бһҪбһӣбһ”бһ¶бһ“бһҖбһ¶бһҡбһӮбһ¶бҹҶбһ‘бҹ’бһҡ бһ“бһ·бһ„бһ‘бһ‘бһҪбһӣбһҹбҹ’бһӮбһ¶бһӣбҹӢбһҷбҹүбһ¶бһ„бһ–бҹҒбһүбһӣбҹҒбһүбһ–бһёбһҖбҹ’бһҡбһҹбһҪбһ„бһўбһ”бҹӢбһҡбҹҶ бһҷбһ»бһңбһҮбһ“ бһ“бһ·бһ„бһҖбһёбһЎбһ¶бҹ”"

  utter_faq/degrees:
    - text: "рҹҺ“ бһҹбһ¶бһӣбһ¶бһ•бҹ’бһҸбһӣбҹӢбһҮбһјбһ“бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҹбһ·бһҖбҹ’бһҹбһ¶бһ…бһ¶бһ”бҹӢбһ–бһёбһҖбһҳбҹ’бһҡбһ·бһҸбҹ–\n- бһ”бһҡбһ·бһүбҹ’бһүбһ¶бһ”бһҸбҹ’бһҡбһҡбһ„ (Associate Degree)\n- бһ”бһҡбһ·бһүбҹ’бһүбһ¶бһ”бһҸбҹ’бһҡ (Bachelor's Degree)\n- бһўбһ“бһ»бһ”бһҺбҹ’бһҢбһ·бһҸ (Master's Degree)"

  utter_faq/dormitory:
    - text: "рҹҸў бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһ“бһ·бһҹбҹ’бһҹбһ·бһҸбһҳбһҖбһ–бһёбһҒбҹҒбһҸбҹ’бһҸбһҶбҹ’бһ„бһ¶бһҷ бһҹбһ¶бһҖбһӣбһңбһ·бһ‘бҹ’бһҷбһ¶бһӣбҹҗбһҷбһўбһ„бҹ’бһӮбһҡбһҳбһ¶бһ“бһ•бҹ’бһҸбһӣбҹӢбһҮбһјбһ“бһҖбһ“бҹ’бһӣбҹӮбһ„бһҹбҹ’бһ“бһ¶бһҖбҹӢбһ“бҹ… бһ”бҹ’бһҡбһҖбһ”бһҠбҹ„бһҷбһҹбһ»бһңбһҸбҹ’бһҗбһ·бһ—бһ¶бһ– бһ“бһ·бһ„бһ—бһ¶бһ–бһ„бһ¶бһҷбһҹбҹ’бһҡбһҪбһӣбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҖбһ¶бһҡбһҡбҹҖбһ“бһҹбһјбһҸбҹ’бһҡбҹ”"

  utter_faq/tuition:
    - text: "рҹ’° бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһӣбһҳбҹ’бһўбһ·бһҸбһ‘бһ¶бһҖбҹӢбһ‘бһ„бһ“бһ№бһ„бһҸбһҳбҹ’бһӣбҹғбһҹбһ·бһҖбҹ’бһҹбһ¶ (Tuition Fee) бһҹбһјбһҳбһ‘бһ¶бһҖбҹӢбһ‘бһ„бһҳбһҖбһҖбһ¶бһ“бҹӢбһӣбҹҒбһҒ 017 671 825 / 070 853 537 бһ¬бһҶбһ¶бһҸбһ‘бҹ…бһҖбһ¶бһ“бҹӢбһ бҹ’бһңбҹҒбһҹбһ”бҹҠбһ»бһҖбһ•бҹҒбһҖ 'Angkor University' бһ•бҹ’бһ‘бһ¶бһӣбҹӢбһҸбҹӮбһҳбҹ’бһҸбһ„ бһҠбһҫбһҳбҹ’бһ”бһёбһ‘бһ‘бһҪбһӣбһ”бһ¶бһ“бһҖбһ¶бһҡбһ•бҹ’бһҸбһӣбҹӢбһҮбһјбһ“ бһ“бһ·бһ„бһўбһ¶бһ бһ¶бһҡбһјбһ”бһҖбһҡбһҺбҹҚбһҗбҹ’бһҳбһёбҹ—! рҹҳҠ"

  utter_ask_continue:
    - text: "бһҸбһҫбһўбҹ’бһ“бһҖбһ…бһ„бҹӢбһ”бһ“бҹ’бһҸбһҖбһ¶бһҡбһ’бҹ’бһңбһҫбһҸбҹҒбһҹбҹ’бһҸбһҠбҹӮбһҡбһ¬бһ‘бҹҒ? (бһ”бһ¶бһ‘,бһ…бһ¶бһҹ/бһ‘бҹҒ) (yes/no)"

  utter_survey_stopped:
    - text: "бһҖбһ¶бһҡбһ’бҹ’бһңбһҫбһҸбҹҒбһҹбҹ’бһҸбһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“бһ”бһүбҹ’бһҲбһ”бҹӢ! рҹӣ‘ бһ‘бһ·бһ“бҹ’бһ“бһ“бҹҗбһҷбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“бһҖбһҸбҹӢбһҸбҹ’бһҡбһ¶бҹ” бһҹбһјбһҳбһңбһ¶бһҷбһ–бһ¶бһҖбҹ’бһҷ 'бһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳ' бһҠбһҫбһҳбҹ’бһ”бһёбһ”бһ“бҹ’бһҸ бһ¬ 'бһӣбһ‘бҹ’бһ’бһ•бһӣ' бһҠбһҫбһҳбҹ’бһ”бһёбһҳбһҫбһӣбһҖбһ¶бһҡбһ‘бһ¶бһҷбһ‘бһ»бһҖбһ”бһҺбҹ’бһҸбҹ„бҹҮбһўбһ¶бһҹбһ“бҹ’бһ“бҹ”"

  utter_default_fallback:
    - text: "бһҒбҹ’бһүбһ»бҹҶбһҳбһ·бһ“бһҹбһјбһңбһҷбһӣбҹӢбһ–бһёбһўбҹ’бһңбһёбһҠбҹӮбһӣбһўбҹ’бһ“бһҖбһҹбһҡбһҹбҹҒбһҡбһ‘бҹҒ рҹҳ…\n\nбһ“бҹҒбҹҮбһҮбһ¶бһўбҹ’бһңбһёбһҠбҹӮбһӣбһҒбҹ’бһүбһ»бҹҶбһўбһ¶бһ…бһҮбһҪбһҷбһ”бһ¶бһ“бҹ–\nрҹҺҜ бһңбһ¶бһҷ **'start'** (бһҠбһҫбһҳбҹ’бһ”бһёбһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳбһ’бҹ’бһңбһҫбһҸбҹҒбһҹбҹ’бһҸбһҡбһҫбһҹбһҮбҹҶбһ“бһ¶бһү)\nвқ“ бһңбһ¶бһҷ **'help'** (бһҠбһҫбһҳбҹ’бһ”бһёбһҳбһҫбһӣбһҳбһ»бһҒбһ„бһ¶бһҡбһӣбһҳбҹ’бһўбһ·бһҸ)\nрҹҸ« бһҹбһҪбһҡбһҹбҹҶбһҺбһҪбһҡбһ–бһё бһҹбһ¶бһҖбһӣбһңбһ·бһ‘бҹ’бһҷбһ¶бһӣбҹҗбһҷбһўбһ„бҹ’бһӮбһҡ"

  utter_chitchat/bot_challenge:
